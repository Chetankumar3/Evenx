# ==============================================================================
# EVENX — single shared environment file. Copy to Infra/.env and fill in.
# One env is sent to ALL containers (main, statesync, restorer). Each service
# reads only the keys it needs; unused keys are harmless.
# ==============================================================================

# --- Postgres (main service only; statesync reads it for rehydration) ---------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=evenx
POSTGRES_USER=evenx
POSTGRES_PASSWORD=evenx_dev_password
# Full DSN form, used by Go (statesync). Keep in sync with the pieces above.
DATABASE_URL=postgres://evenx:evenx_dev_password@postgres:5432/evenx?sslmode=disable

# --- Redis (shared by all three services) -------------------------------------
# Go services use REDIS_ADDR (host:port); node uses REDIS_URL.
REDIS_ADDR=redis:6379
REDIS_URL=redis://redis:6379
REDIS_DB=0
# Keyspace-notification DB index restorer listens on must match REDIS_DB:
# restorer subscribes to "__keyevent@<REDIS_DB>__:expired".

# --- Auth (the ONLY secret shared between main and statesync) ------------------
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRES_SECONDS=7200

# --- Booking locks ------------------------------------------------------------
# Lock hold time in seconds, used by statesync (SETEX) for both models.
LOCK_TTL=600

# --- Service ports ------------------------------------------------------------
MAIN_PORT=3000
STATESYNC_PORT=8080

# --- CORS: frontend origin allowed to call main / open WS ---------------------
FRONTEND_ORIGIN=http://localhost:5173

# --- Frontend (Vite) — only read at frontend build/dev time -------------------
VITE_API_BASE_URL=http://localhost:3000
VITE_WS_BASE_URL=ws://localhost:8080